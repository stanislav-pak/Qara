# Copy to .env locally. On Vercel: Project → Settings → Environment Variables (Production / Preview).
# Rebuild after changing vars — VITE_* are inlined at build time.

# Supabase (https://supabase.com/dashboard) — RLS жобада SQL арқылы қосылады
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public /book page: auth.users.id of the business owner (same UUID as in supabase/public_booking_rls.sql)
# Example format: 00000000-0000-0000-0000-000000000000
VITE_BOOKING_OWNER_ID=
